#!/bin/sh
# Pre-push hook: rebase on upstream/main before pushing
#
# Ensures your feature branch is always based on the latest upstream/main.
# Uses rebase (not merge) to keep a clean, linear history.
#
# Requirements:
#   - 'upstream' remote pointing to the main repository
#   - No uncommitted changes (commit or stash before pushing)
#
# To skip this hook temporarily: git push --no-verify

set -e

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# --- Step 1: Dependency sync check ---
echo "${BLUE}==> Checking dependency sync...${NC}"
if ! node scripts/sync-dependencies.mjs; then
  echo "${RED}Error: Failed to sync dependencies${NC}"
  exit 1
fi

# Check if sync modified files (package.json, lock files)
# Only check files that sync-dependencies can modify, not the entire worktree
if ! git diff --quiet HEAD -- package.json '*/package.json' pnpm-lock.yaml '*/pnpm-lock.yaml' 2>/dev/null; then
  echo "${RED}========================================${NC}"
  echo "${RED}Dependency sync made changes.${NC}"
  echo "${RED}========================================${NC}"
  echo "${YELLOW}Stage and commit them, then push again:${NC}"
  echo "  git add package.json pnpm-lock.yaml"
  echo "  git commit -m 'chore: sync dependencies'"
  echo "  git push"
  exit 1
fi

# --- Step 2: Get current branch, skip if not a feature branch ---
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Skip for main, master, and release-please branches
case "$CURRENT_BRANCH" in
  main|master|release-please--*)
    echo "${GREEN}==> Skipping rebase for branch: ${CURRENT_BRANCH}${NC}"
    exit 0
    ;;
esac

echo "${BLUE}==> Pre-push hook: ${CURRENT_BRANCH}${NC}"

# --- Step 3: Check for uncommitted changes ---
if ! git diff --quiet HEAD --; then
  echo "${RED}========================================${NC}"
  echo "${RED}Uncommitted changes detected.${NC}"
  echo "${RED}========================================${NC}"
  echo "${YELLOW}Commit or stash your changes before pushing:${NC}"
  echo "  git add -A && git commit -m 'wip: save progress'"
  echo "  # or"
  echo "  git stash"
  exit 1
fi

# --- Step 4: Check upstream remote ---
if ! git remote get-url upstream >/dev/null 2>&1; then
  echo "${YELLOW}Warning: No 'upstream' remote configured. Skipping rebase.${NC}"
  echo "${YELLOW}Add it with:${NC}"
  echo "  git remote add upstream git@github.com:modbus2mqtt/oci-lxc-deployer.git"
  exit 0
fi

# --- Step 5: Fetch upstream ---
echo "${BLUE}==> Fetching upstream...${NC}"
if ! git fetch upstream; then
  echo "${YELLOW}Warning: Failed to fetch upstream. Continuing without rebase.${NC}"
  exit 0
fi

# --- Step 6: Check if rebase is needed ---
if git merge-base --is-ancestor upstream/main HEAD; then
  echo "${GREEN}✓ Already up-to-date with upstream/main${NC}"
  exit 0
fi

# --- Step 7: Rebase on upstream/main ---
echo "${BLUE}==> Rebasing ${CURRENT_BRANCH} on upstream/main...${NC}"
if git rebase upstream/main; then
  echo "${GREEN}========================================${NC}"
  echo "${GREEN}✓ Rebased on upstream/main successfully${NC}"
  echo "${GREEN}========================================${NC}"
  exit 0
else
  echo "${RED}========================================${NC}"
  echo "${RED}Rebase conflict detected!${NC}"
  echo "${RED}========================================${NC}"
  echo ""
  echo "${YELLOW}To resolve and continue:${NC}"
  echo "  1. Fix conflicts in your editor"
  echo "  2. Stage resolved files: git add <files>"
  echo "  3. Continue rebase: git rebase --continue"
  echo "  4. Push again: git push"
  echo ""
  echo "${YELLOW}To abort the rebase:${NC}"
  echo "  git rebase --abort"
  exit 1
fi
