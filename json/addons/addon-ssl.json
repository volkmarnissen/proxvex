{
  "name": "SSL/HTTPS",
  "description": "Enable HTTPS via nginx reverse proxy, native app configuration, or certificate provisioning only.",
  "tags": ["security", "network"],

  "compatible_with": "*",

  "parameters": [
    {
      "id": "ssl.mode",
      "name": "SSL Mode",
      "type": "enum",
      "required": true,
      "default": "proxy",
      "certtype": "server",
      "enumValues": [
        { "name": "Proxy (nginx)", "value": "proxy" },
        { "name": "Native", "value": "native" },
        { "name": "Certificates only", "value": "certs" }
      ],
      "description": "Proxy: nginx reverse proxy handles HTTPS. Native: app configures HTTPS itself. Certs: only provision certificates (no ports, no proxy)."
    },
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "required": false,
      "default": "",
      "advanced": true,
      "description": "The HTTP port of the application to be proxied."
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "required": false,
      "default": "",
      "advanced": true,
      "description": "The HTTPS port to listen on."
    }
  ],

  "properties": [
    { "id": "ssl.addon_volumes", "value": "certs=/etc/ssl/addon,0700,0:0" }
  ],

  "installation": {
    "pre_start": [
      { "name": "150-conf-create-storage-volumes-for-lxc.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "156-conf-generate-certificates.json", "after": "150-conf-create-storage-volumes-for-lxc.json" },
      { "name": "159-conf-enable-ssl-app.json", "after": "156-conf-generate-certificates.json" },
      { "name": "170-conf-add-ssl-capabilities.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "165-conf-register-hookscript.json", "after": "100-conf-create-configure-lxc.json" }
    ],
    "post_start": [
      "332-post-install-on-start-dispatcher.json",
      { "name": "325-post-inject-ssl-proxy-compose.json", "after": "320-post-upload-docker-compose-files.json" },
      "340-post-install-ssl-proxy-on-start.json"
    ]
  },

  "reconfigure": {
    "pre_start": [
      { "name": "150-conf-create-storage-volumes-for-lxc.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "156-conf-generate-certificates.json", "after": "150-conf-create-storage-volumes-for-lxc.json" },
      { "name": "159-conf-enable-ssl-app.json", "after": "156-conf-generate-certificates.json" },
      { "name": "170-conf-add-ssl-capabilities.json", "after": "100-conf-create-configure-lxc.json" },
      { "name": "165-conf-register-hookscript.json", "after": "100-conf-create-configure-lxc.json" }
    ],
    "post_start": [
      "332-post-install-on-start-dispatcher.json",
      { "name": "325-post-inject-ssl-proxy-compose.json", "after": "320-post-upload-docker-compose-files.json" },
      "340-post-install-ssl-proxy-on-start.json"
    ]
  },

  "disable": {
    "pre_start": [
      "158-conf-disable-ssl-app.json"
    ],
    "post_start": [
      "345-post-disable-ssl-proxy.json"
    ]
  },

  "upgrade": [
    "332-post-install-on-start-dispatcher.json",
    "340-post-install-ssl-proxy-on-start.json"
  ],

  "notes_key": "ssl"
}
