{
  "execute_on": "ve",
  "name": "Generate Certificates",
  "skip_if_all_missing": [
    "ca_key_b64"
  ],
  "parameters": [
    {
      "id": "vm_id",
      "name": "VM ID",
      "type": "string"
    },
    {
      "id": "ca_key_b64",
      "name": "CA Key",
      "type": "string",
      "internal": true,
      "secure": true
    },
    {
      "id": "ca_cert_b64",
      "name": "CA Cert",
      "type": "string",
      "internal": true
    },
    {
      "id": "hostname",
      "name": "Hostname",
      "type": "string",
      "required": true
    },
    {
      "id": "domain_suffix",
      "name": "Domain Suffix",
      "type": "string",
      "default": ".local",
      "advanced": true,
      "description": "FQDN = hostname + domain_suffix"
    },
    {
      "id": "ssl.needs_server_cert",
      "name": "Needs Server Cert",
      "type": "boolean",
      "default": "true",
      "advanced": true,
      "description": "Generate server certificate (privkey.pem, cert.pem, fullchain.pem)"
    },
    {
      "id": "ssl.needs_ca_cert",
      "name": "Needs CA Cert",
      "type": "boolean",
      "default": "false",
      "advanced": true,
      "description": "Write CA certificate (chain.pem)"
    },
    {
      "id": "uid",
      "name": "UID",
      "type": "string",
      "default": "0",
      "advanced": true
    },
    {
      "id": "gid",
      "name": "GID",
      "type": "string",
      "default": "0",
      "advanced": true
    },
    {
      "id": "mapped_uid",
      "name": "Mapped UID",
      "type": "string",
      "advanced": true,
      "description": "UID mapping on the host for unprivileged containers"
    },
    {
      "id": "mapped_gid",
      "name": "Mapped GID",
      "type": "string",
      "advanced": true,
      "description": "GID mapping on the host for unprivileged containers"
    },
    {
      "id": "cert_dir_override",
      "name": "Cert Dir Override",
      "type": "string",
      "advanced": true,
      "description": "If set, use this path directly as cert directory instead of computing from shared_volpath"
    },
    {
      "id": "ssl_additional_san",
      "name": "Additional SANs",
      "type": "string",
      "advanced": true,
      "description": "Extra SAN entries for the server certificate (e.g. DNS:registry-1.docker.io,DNS:index.docker.io)"
    }
  ],
  "commands": [
    {
      "name": "Generate Certificates",
      "script": "conf-generate-certificates.sh",
      "library": "cert-common.sh",
      "outputs": [
        "certs_generated"
      ]
    }
  ]
}
