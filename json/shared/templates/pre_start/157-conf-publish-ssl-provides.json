{
  "name": "Publish SSL Connection Info",
  "description": "Publishes protocol and port as stack provides when SSL addon is active.",
  "execute_on": "ve",
  "skip_if_all_missing": ["ssl_mode"],
  "parameters": [
    { "id": "ssl_mode", "name": "SSL Mode", "type": "string", "required": true, "description": "SSL mode: proxy, native, or certs" },
    { "id": "hostname", "name": "Hostname", "type": "string", "required": true, "description": "Container hostname for provides publishing" },
    { "id": "domain_suffix", "name": "Domain Suffix", "type": "string", "default": ".local", "advanced": true, "description": "FQDN suffix appended to hostname" },
    { "id": "http_port", "name": "HTTP Port", "type": "string", "default": "", "advanced": true, "description": "HTTP port of the application" },
    { "id": "https_port", "name": "HTTPS Port", "type": "string", "default": "", "advanced": true, "description": "HTTPS port of the application" }
  ],
  "commands": [{
    "name": "Publish SSL Connection Info",
    "script": "conf-publish-ssl-provides.sh",
    "outputs": []
  }]
}
