{
  "execute_on": "lxc",
  "name": "Inject SSL Proxy Compose",
  "description": "Adds an nginx-ssl-proxy service to the Docker-Compose file and removes external HTTP port mapping. Only runs for Docker-Compose apps with SSL addon enabled.",
  "skip_if_all_missing": ["compose_project"],
  "parameters": [
    {
      "id": "compose_project",
      "name": "Compose Project",
      "type": "string",
      "required": true,
      "description": "Docker-Compose project name"
    },
    {
      "id": "addon_ssl_mode",
      "name": "SSL Mode",
      "type": "string",
      "required": true,
      "description": "SSL mode: proxy (nginx) or native"
    },
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "required": true,
      "description": "Application HTTP port"
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "required": true,
      "description": "HTTPS port for nginx proxy"
    }
  ],
  "commands": [{
    "name": "Inject SSL Proxy",
    "script": "post-inject-ssl-proxy-compose.sh",
    "description": "Add nginx-ssl-proxy service to compose file"
  }]
}
