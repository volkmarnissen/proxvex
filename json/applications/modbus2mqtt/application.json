{
  "name": "Modbus2MQTT",
  "description": "Bridge that exposes Modbus RTU/TCP devices over MQTT with Home Assistant auto-discovery. Runs as an LXC container on Proxmox with optional HTTPS and OIDC authentication.",
  "extends": "oci-image",
  "icon": "icon.png",
  "tags": ["automation", "iot"],
  "supported_addons": ["addon-oidc", "addon-ssl"],
  "oidc_roles": [
    { "key": "admin", "display_name": "Administrator", "group": "modbus2mqtt" }
  ],
  "properties": [
    { "id": "hostname", "default": "modbus2mqtt" },
    { "id": "volumes", "default": "config=/config\ndata=/data\nssl=/ssl" },
    { "id": "envs", "default": "HTTP_PORT=3000\nHTTPS_PORT=3443" },
    { "id": "rootfs_storage", "default": "local-zfs" },
    { "id": "volume_storage", "default": "local-zfs", "required": true },
    { "id": "oci_image", "value": "ghcr.io/modbus2mqtt/modbus2mqtt:{{oci_image_tag}}" },
    { "id": "wait_for_network", "value": "true" },
    { "id": "uid", "value": "1000" },
    { "id": "gid", "value": "1000" },
    { "id": "username", "value": "node" },
    { "id": "http_port", "value": "3000" },
    { "id": "https_port", "value": "3443" },
    { "id": "volume_backup", "value": "true" },
    { "id": "ssl_mode", "value": "native" },
    { "id": "oidc_callback_path", "value": "/api/auth/callback" },
    { "id": "oidc_required_role", "value": "admin" }
  ],
  "installation": {},
  "url": "https://github.com/modbus2mqtt/modbus2mqtt",
  "documentation": "https://github.com/modbus2mqtt/modbus2mqtt/blob/main/README.md",
  "source": "https://github.com/modbus2mqtt/modbus2mqtt"
}
