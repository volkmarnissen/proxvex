{
  "name": "Postgres",
  "description": "Postgres SQL Database open Source",
  "extends": "oci-image",
  "icon": "icon.svg",
  "properties": [
    { "id": "hostname", "default": "postgres" },
    { "id": "volumes", "default": "data=var/lib/postgresql/data\ninitdb=docker-entrypoint-initdb.d" },
    { "id": "envs", "default": "GID=70\nPGDATA=/var/lib/postgresql/data/pgdata\nPOSTGRES_DB=postgres\nPOSTGRES_PASSWORD={{ POSTGRES_PASSWORD }}\nPOSTGRES_PORT=5432\nPOSTGRES_USER=postgres\nPOSTGRES_VERSION=16-alpine\nUID=70" },
    { "id": "oci_image", "value": "postgres:{{oci_image_tag}}" },
    { "id": "uid", "value": "70" },
    { "id": "username", "value": "postgres" },
    { "id": "ssl_mode", "value": "certs" },
    { "id": "https_port", "value": "5432" },
    { "id": "ssl.addon_volumes", "value": "certs=/certs,0700,70:70\nproxvex=/etc/proxvex,0755,0:0" },
    { "id": "startup_order", "value": "10" },
    { "id": "startup_up", "value": "15" }
  ],
  "installation": {},
  "check": {
    "check": [
      "check-pg-ssl.json"
    ]
  },
  "tags": ["database"],
  "stacktype": "postgres",
  "stack_usage": [
    {
      "stacktype": "postgres",
      "vars": [
        { "name": "POSTGRES_PASSWORD", "replacement": "manual" },
        { "name": "API_LOGIN_PASSWORD", "replacement": "manual" },
        { "name": "JWT_SECRET", "replacement": "manual" },
        { "name": "PGADMIN_DEFAULT_PASSWORD", "replacement": "manual" }
      ]
    }
  ]
}
