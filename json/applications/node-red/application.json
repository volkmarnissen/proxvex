{
  "name": "Node Red",
  "description": "Node-RED is a flow-based programming tool for wiring together hardware devices, APIs and online services.",
  "extends": "oci-image",
  "icon": "icon.svg",
  "supports": ["serial_tty"],
  "properties": [
    { "id": "hostname", "default": "node-red" },
    { "id": "volumes", "default": "data=data\ncerts=certs" },
    { "id": "envs", "default": "GID=1000\nNODERED_PORT=1880\nNODERED_VERSION=latest\nTZ=Europe/Berlin\nUID=1000" },
    { "id": "oci_image", "value": "nodered/node-red:{{oci_image_tag}}" },
    { "id": "uid", "value": "1000" },
    { "id": "username", "value": "root" }
  ],
  "installation": {
    "pre_start": [
      "0-upload-settings-js.json"
    ]
  },
  "source": "https://github.com/node-red/node-red-docker",
  "tags": [
    "api",
    "development"
  ],
  "supported_addons": ["addon-oidc"],
  "oidc_roles": [
    { "key": "admin", "display_name": "Administrator" }
  ]
}
