{
  "name": "Gptwol",
  "description": "A web application to manage Wake-on-LAN (WOL) for your devices. Monitor device status, schedule wake-up tasks via cron, and send WOL packets through a simple web interface.",
  "extends": "oci-image",
  "icon": "icon.png",
  "properties": [
    { "id": "hostname", "default": "gptwol" },
    { "id": "volumes", "default": "appdata_db=app/db\nappdata_cron=etc/cron.d" },
    { "id": "envs", "default": "TZ=Europe/Berlin" },
    { "id": "rootfs_storage", "default": "local-zfs" },
    { "id": "volume_storage", "default": "local-zfs", "required": true },
    { "id": "oci_image", "value": "misterbabou/gptwol:{{oci_image_tag}}" },
    { "id": "uid", "value": "0" },
    { "id": "username", "value": "root" },
    { "id": "http_port", "value": "5000" },
    { "id": "oidc_callback_path", "value": "/oidc/callback" }
  ],
  "installation": {},
  "tags": [
    "infrastructure"
  ],
  "supported_addons": ["addon-oidc"],
  "oidc_roles": [
    { "key": "admin", "display_name": "Administrator" }
  ],
  "stacktype": "oidc"
}
