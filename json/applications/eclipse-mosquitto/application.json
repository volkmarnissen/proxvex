{
  "name": "Eclipse Mosquitto",
  "description": "Eclipse Mosquitto MQTT Broker",
  "extends": "oci-image",
  "icon": "icon.svg",
  "properties": [
    { "id": "hostname", "default": "eclipse-mosquitto" },
    { "id": "volumes", "default": "config=mosquitto/config" },
    { "id": "envs", "default": "GID=1883\nMOSQUITTO_VERSION=2\nMQTTS_PORT=8883\nMQTT_PORT=1883\nMQTT_WS_PORT=9001\nUID=1883" },
    { "id": "oci_image", "value": "eclipse-mosquitto:{{oci_image_tag}}" },
    { "id": "uid", "value": "1883" },
    { "id": "username", "value": "root" },
    { "id": "ssl_mode", "value": "certs" },
    { "id": "ssl.addon_volumes", "value": "certs=/mosquitto/config/certs,0700,1883:1883\nproxvex=/etc/proxvex,0755,0:0" },
    { "id": "ssl.needs_server_cert", "value": "true" },
    { "id": "ssl.needs_ca_cert", "value": "true" }
  ],
  "installation": {
    "pre_start": [
      "0-upload-mosquitto-configuration.json"
    ]
  },
  "url": "https://mosquitto.org/",
  "documentation": "https://mosquitto.org/documentation/",
  "source": "https://github.com/eclipse-mosquitto/mosquitto",
  "tags": [
    "iot",
    "messaging"
  ]
}
