{
  "name": "OCI LXC Deployer",
  "description": "Deploys and manages LXC containers on Proxmox from OCI images via a web UI and API, and lets you easily define custom container services",
  "extends": "oci-image",
  "icon": "favicon.svg",
  "tags": ["infrastructure"],
  "supported_addons": ["addon-oidc"],
  "oidc_roles": [
    { "key": "admin", "display_name": "Administrator", "group": "deployer" }
  ],
  "parameters": [
    {
      "id": "volumes",
      "name": "Volumes",
      "type": "string",
      "multiline": true,
      "required": false,
      "description": "Volume mappings for the container (one per line, format: name=path or name=path,mode)"
    },
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "default": "3080",
      "required": false,
      "advanced": true
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "default": "3443",
      "required": false,
      "advanced": true
    },
    {
      "id": "oci_image_tag",
      "name": "Version",
      "type": "string",
      "required": true,
      "description": "OCI image tag / version to deploy (e.g. 'latest', 'v1.2.3'). Default comes from versions.sh (OCI_oci_lxc_deployer_TAG)."
    }
  ],
  "properties": [
    { "id": "hostname", "value": "oci-lxc-deployer" },
    { "id": "oci_image", "value": "ghcr.io/modbus2mqtt/oci-lxc-deployer:{{oci_image_tag}}" },
    { "id": "uid", "value": "1001" },
    { "id": "gid", "value": "1001" },
    { "id": "username", "value": "lxc" },
    { "id": "http_port", "value": "{{http_port}}" },
    { "id": "https_port", "value": "{{https_port}}" },
    { "id": "volume_backup", "value": "true" },
    { "id": "volumes", "value": "config=/config\nsecure=/secure,0700" },
    { "id": "ssl_mode", "value": "native" },
    { "id": "oidc_callback_path", "value": "/api/auth/callback" },
    { "id": "oidc_required_role", "value": "admin" }
  ],
  "installation": {},
  "upgrade": {
    "image": [
      "005-host-trust-deployer-ca.json",
      "011-host-get-oci-image.json"
    ],
    "create_ct": [
      { "name": "050-set-project-parameters.json", "category": "create_ct" },
      { "name": "100-conf-create-configure-lxc.json", "category": "pre_start" }
    ],
    "pre_start": [
      "101-conf-restore-settings.json",
      "107-conf-oci-lxc-configuration.json"
    ],
    "replace_ct": [
      "900-schedule-deployer-upgrade.json"
    ]
  },
  "check": {
    "check": [
      "check-oidc-endpoint.json"
    ]
  },
  "url": "https://github.com/modbus2mqtt/oci-lxc-deployer",
  "documentation": "https://github.com/modbus2mqtt/oci-lxc-deployer/blob/main/README.md",
  "source": "https://github.com/modbus2mqtt/oci-lxc-deployer",
  "vendor": "Carcam 360"
}