{
  "name": "Nginx Unprivileged",
  "description": "Unprivileged NGINX Dockerfiles",
  "extends": "oci-image",
  "icon": "nginx.svg",
  "supported_addons": ["addon-oidc", "addon-ssl", "addon-acme"],
  "oidc_roles": [
    { "key": "admin", "display_name": "Administrator" }
  ],
  "properties": [
    { "id": "hostname", "default": "nginx" },
    { "id": "volumes", "default": "conf=/etc/nginx/conf.d" },
    { "id": "envs", "default": "NGINX_VERSION=alpine" },
    { "id": "oci_image", "value": "nginxinc/nginx-unprivileged:{{oci_image_tag}}" },
    { "id": "uid", "value": "101" },
    { "id": "username", "value": "root" },
    { "id": "http_port", "value": "8080" },
    { "id": "oidc_callback_path", "value": "/oauth2/callback" },
    { "id": "oidc_required_role", "value": "" }
  ],
  "installation": {
    "pre_start": [
      "conf-write-default-config.json",
      "conf-write-reload-hook.json"
    ]
  },
  "reconfigure": {
    "pre_start": [
      "conf-write-default-config.json",
      "conf-write-reload-hook.json"
    ]
  },
  "url": "https://github.com/nginx/docker-nginx-unprivileged",
  "source": "https://github.com/nginx/docker-nginx-unprivileged",
  "tags": [
    "infrastructure"
  ]
}
