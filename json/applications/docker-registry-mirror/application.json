{
  "name": "Docker Registry Mirror",
  "description": "Pull-through cache for Docker Hub. Caches images locally to avoid rate limits.",
  "extends": "docker-compose",
  "icon": "icon.svg",
  "parameters": [
    {
      "id": "DOCKERHUB_USERNAME",
      "name": "Docker Hub Username",
      "type": "string",
      "required": false,
      "description": "Docker Hub username for authenticated pulls (higher rate limits). Leave empty for anonymous."
    },
    {
      "id": "DOCKERHUB_TOKEN",
      "name": "Docker Hub Token",
      "type": "string",
      "secure": true,
      "required": false,
      "description": "Docker Hub Personal Access Token (PAT) for authenticated pulls."
    }
  ],
  "properties": [
    { "id": "hostname", "default": "docker-registry-mirror" },
    { "id": "compose_file", "default": "file:docker-registry-mirror.docker-compose.yml" },
    { "id": "ostype", "value": "alpine" },
    { "id": "ssl_mode", "value": "native" },
    { "id": "https_port", "value": "443" },
    { "id": "ssl.addon_volumes", "value": "certs=certs,0755,0:0\nproxvex=/etc/proxvex,0755,0:0" },
    { "id": "ssl.needs_server_cert", "value": "true" },
    { "id": "ssl.needs_ca_cert", "value": "true" },
    { "id": "ssl_additional_san", "value": "DNS:registry-1.docker.io,DNS:index.docker.io" },
    { "id": "startup_order", "value": "5" },
    { "id": "startup_up", "value": "10" }
  ],
  "installation": {
    "image": [
      "005-host-trust-deployer-ca.json"
    ]
  },
  "check": {
    "check": [
      "check-registry-mirror.json"
    ]
  },
  "supported_addons": ["addon-ssl"],
  "required_addons": ["addon-ssl"],
  "tags": ["infrastructure"],
  "url": "https://docs.docker.com/registry/",
  "documentation": "https://docs.docker.com/registry/recipes/mirror/",
  "source": "https://github.com/distribution/distribution"
}
