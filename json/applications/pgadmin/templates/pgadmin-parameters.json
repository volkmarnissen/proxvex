{
  "execute_on": "ve",
  "name": "Set Parameters",
  "description": "Set application-specific parameters for pgAdmin",
  "parameters": [
    {
      "id": "hostname",
      "name": "Hostname",
      "type": "string",
      "default": "pgadmin",
      "required": true,
      "description": "Hostname for the pgAdmin container"
    },
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "default": "5050",
      "required": false,
      "advanced": true,
      "description": "Port number for pgAdmin HTTP server (default: 5050)"
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "default": "5443",
      "required": false,
      "advanced": true,
      "description": "Port number for HTTPS access (default: 5443)"
    }
  ],
  "commands": [
    {
      "properties": [
        { "id": "hostname", "value": "{{hostname}}" },
        { "id": "oci_image", "value": "dpage/pgadmin4" },
        { "id": "http_port", "value": "{{http_port}}" },
        { "id": "https_port", "value": "{{https_port}}" },
        { "id": "uid", "value": "5050" },
        { "id": "gid", "value": "5050" },
        { "id": "username", "value": "pgadmin" }
      ]
    }
  ]
}
