{
  "name": "pgAdmin",
  "description": "Web-based administration and development platform for PostgreSQL",
  "extends": "oci-image",
  "icon": "icon.svg",
  "tags": ["database"],
  "stacktype": "pgadmin",
  "properties": [
    { "id": "envs", "default": "PGADMIN_DEFAULT_EMAIL=admin@example.com\nPGADMIN_DEFAULT_PASSWORD={{ PGADMIN_DEFAULT_PASSWORD }}" },
    { "id": "disk_size", "value": "1.5" }
  ],
  "installation": {
    "image": [
      {
        "name": "pgadmin-parameters.json",
        "position": "start"
      }
    ]
  },
  "stack_usage": [
    {
      "stacktype": "pgadmin",
      "vars": [
        { "name": "PGADMIN_DEFAULT_PASSWORD", "replacement": "manual" }
      ]
    }
  ]
}
