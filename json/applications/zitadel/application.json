{
  "name": "zitadel",
  "description": "ZITADEL is an open source identity management platform.",
  "extends": "docker-compose",
  "icon": "icon.png",
  "parameters": [
    {
      "id": "hostname",
      "name": "Hostname",
      "type": "string",
      "required": false,
      "description": "Hostname for the Docker Compose container. Required when creating an application from the docker-compose framework.",
      "template": "application.json",
      "default": "zitadel"
    },
    {
      "id": "volumes",
      "name": "Volumes",
      "type": "string",
      "multiline": true,
      "required": false,
      "description": "One per line: key=/container/path",
      "template": "150-conf-create-storage-volumes-for-lxc.json",
      "templatename": "Create Storage Volumes for LXC",
      "default": "bootstrap=/bootstrap,0777"
    },
    {
      "id": "ZITADEL_EXTERNALDOMAIN",
      "name": "External Domain",
      "type": "string",
      "required": false,
      "description": "Public domain name for Zitadel (used in URLs and OIDC config)",
      "default": "{{ hostname }}"
    },
    {
      "id": "compose_file",
      "name": "Docker Compose File",
      "type": "string",
      "upload": true,
      "required": true,
      "description": "Docker Compose YAML file (upload). Upload this file first to extract service information.",
      "template": "application.json",
      "default": ""
    }
  ],
  "properties": [
    {
      "id": "compose_file",
      "value": ""
    },
    {
      "id": "ostype",
      "value": "alpine"
    },
    {
      "id": "ssl_mode",
      "value": "native"
    },
    {
      "id": "https_port",
      "value": "8443"
    },
    {
      "id": "ssl.addon_volumes",
      "value": "certs=certs,0755,0:0"
    },
    {
      "id": "ssl.needs_server_cert",
      "value": "true"
    },
    {
      "id": "ssl.needs_ca_cert",
      "value": "true"
    },
    {
      "id": "startup_order",
      "value": "20"
    },
    {
      "id": "startup_up",
      "value": "15"
    }
  ],
  "dependencies": [
    {
      "application": "postgres"
    }
  ],
  "installation": {},
  "stacktype": [
    "postgres",
    "oidc"
  ],
  "verification": {
    "wait_seconds": 90,
    "checks": {
      "docker_log_no_errors": true,
      "file_exists": "/bootstrap/login-client.pat"
    }
  }
}
