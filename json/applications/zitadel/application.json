{
  "name": "zitadel",
  "description": "ZITADEL is an open source identity management platform.",
  "extends": "docker-compose",
  "icon": "icon.png",
  "parameters": [
    {
      "id": "hostname",
      "name": "Hostname",
      "type": "string",
      "required": false,
      "description": "Hostname for the Docker Compose container. Required when creating an application from the docker-compose framework.",
      "template": "application.json",
      "default": "zitadel"
    },
    {
      "id": "ZITADEL_EXTERNALDOMAIN",
      "name": "External Domain",
      "type": "string",
      "required": false,
      "description": "Public domain name for Zitadel (used in URLs and OIDC config)",
      "default": "{{ hostname }}"
    }
  ],
  "properties": [
    {
      "id": "volumes",
      "default": "bootstrap=bootstrap,0770,1000:1001"
    },
    {
      "id": "compose_file",
      "default": "file:Zitadel.docker-compose.yml"
    },
    {
      "id": "ostype",
      "value": "alpine"
    },
    {
      "id": "ssl_mode",
      "value": "native"
    },
    {
      "id": "https_port",
      "value": "1443"
    },
    {
      "id": "ssl.addon_volumes",
      "value": "certs=certs,0755,0:0"
    },
    {
      "id": "ssl.needs_server_cert",
      "value": "true"
    },
    {
      "id": "ssl.needs_ca_cert",
      "value": "true"
    },
    {
      "id": "startup_order",
      "value": "20"
    },
    {
      "id": "startup_up",
      "value": "15"
    },
    {
      "id": "startup_timeout",
      "value": "300"
    },
    {
      "id": "check_file_paths",
      "value": "/bootstrap/login-client.pat\n/bootstrap/admin-client.pat"
    }
  ],
  "dependencies": [
    {
      "application": "postgres"
    }
  ],
  "installation": {
    "post_start": [
      "340-post-setup-deployer-in-zitadel.json"
    ]
  },
  "stacktype": [
    "postgres",
    "oidc"
  ]
}
