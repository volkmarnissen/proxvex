{
  "execute_on": "ve",
  "name": "Set Parameters",
  "description": "Set application-specific parameters for PostgREST",
  "parameters": [
    {
      "id": "hostname",
      "name": "Hostname",
      "type": "string",
      "default": "postgrest",
      "required": true,
      "description": "Hostname for the PostgREST container"
    },
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "default": "3000",
      "required": false,
      "advanced": true,
      "description": "Port number for PostgREST HTTP server (default: 3000)"
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "default": "3443",
      "required": false,
      "advanced": true,
      "description": "Port number for HTTPS access (default: 3443)"
    }
  ],
  "commands": [
    {
      "properties": [
        { "id": "hostname", "value": "{{hostname}}" },
        { "id": "http_port", "value": "{{http_port}}" },
        { "id": "https_port", "value": "{{https_port}}" },
        { "id": "compose_project", "value": "postgrest" }
      ]
    }
  ]
}
