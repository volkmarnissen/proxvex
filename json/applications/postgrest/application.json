{
  "name": "PostgREST",
  "description": "PostgreSQL REST API server - automatically creates a RESTful API from a PostgreSQL database",
  "extends": "docker-compose",
  "icon": "icon.svg",
  "tags": ["api", "database"],
  "parameters": [
    {
      "id": "http_port",
      "name": "HTTP Port",
      "type": "string",
      "default": "3000",
      "required": false,
      "advanced": true,
      "description": "Port number for PostgREST HTTP server (default: 3000)"
    },
    {
      "id": "https_port",
      "name": "HTTPS Port",
      "type": "string",
      "default": "3443",
      "required": false,
      "advanced": true,
      "description": "Port number for HTTPS access (default: 3443)"
    }
  ],
  "properties": [
    { "id": "hostname", "default": "postgrest" },
    { "id": "compose_project", "value": "postgrest" },
    {
      "id": "compose_file",
      "value": ""
    },
    { "id": "ssl_mode", "value": "proxy" },
    { "id": "ssl.needs_server_cert", "value": "true" },
    { "id": "ssl.needs_ca_cert", "value": "true" }
  ],
  "dependencies": [
    { "application": "postgres" }
  ],
  "installation": {},
  "stacktype": "postgres",
  "stack_usage": [
    {
      "stacktype": "postgres",
      "vars": [
        { "name": "POSTGRES_PASSWORD", "replacement": "manual" }
      ]
    }
  ]
}
