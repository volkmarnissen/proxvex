{
  "name": "PostgREST",
  "description": "PostgreSQL REST API server - automatically creates a RESTful API from a PostgreSQL database",
  "extends": "docker-compose",
  "icon": "icon.svg",
  "tags": ["api", "database"],
  "parameters": [
    {
      "id": "hostname",
      "name": "Hostname",
      "type": "string",
      "required": false,
      "description": "Hostname for the Docker Compose container.",
      "template": "application.json",
      "default": "postgrest"
    },
    {
      "id": "compose_file",
      "name": "Docker Compose File",
      "type": "string",
      "upload": true,
      "required": true,
      "description": "Docker Compose YAML file (upload).",
      "template": "application.json",
      "default": ""
    }
  ],
  "properties": [
    {
      "id": "compose_file",
      "value": ""
    },
    { "id": "ssl_mode", "value": "proxy" },
    { "id": "ssl.needs_server_cert", "value": "true" },
    { "id": "ssl.needs_ca_cert", "value": "true" }
  ],
  "dependencies": [
    { "application": "postgres" }
  ],
  "installation": {
    "image": [
      "postgrest-parameters.json"
    ]
  },
  "stacktype": "postgres"
}
