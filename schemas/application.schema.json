{
  "$id": "application",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "base-deployable"
    }
  ],
  "type": "object",
  "properties": {
    "extends": {
      "type": "string",
      "pattern": "^(local:|[^:]+).*$"
    },
    "icon": {
      "type": "string",
      "default": "icon.png"
    },
    "url": {
      "type": "string"
    },
    "documentation": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "vendor": {
      "type": "string"
    },
    "stacktype": {
      "type": "string"
    },
    "dependencies": {
      "type": "array",
      "description": "Applications that must be installed before this one (in the same stack)",
      "items": {
        "type": "object",
        "properties": {
          "application": {
            "type": "string",
            "description": "Application ID of the dependency"
          }
        },
        "required": ["application"],
        "additionalProperties": false
      }
    },
    "installation": {
      "$ref": "categorized-templatelist"
    },
    "upgrade": {
      "$ref": "categorized-templatelist"
    },
    "copy-upgrade": {
      "$ref": "categorized-templatelist"
    },
    "copy-rollback": {
      "$ref": "categorized-templatelist"
    },
    "addon-reconfigure": {
      "$ref": "categorized-templatelist"
    },
    "addon": {
      "$ref": "templatelist"
    }
  },
  "required": [
    "installation"
  ],
  "unevaluatedProperties": false
}
