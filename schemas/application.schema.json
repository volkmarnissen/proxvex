{
  "$id": "application",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [
    {
      "$ref": "base-deployable"
    },
    {
      "if": {
        "required": ["supported_addons"],
        "properties": {
          "supported_addons": {
            "type": "array",
            "contains": { "const": "addon-oidc" }
          }
        }
      },
      "then": {
        "required": ["oidc_roles"]
      }
    },
    {
      "if": {
        "not": {
          "anyOf": [
            { "required": ["extends"] },
            { "properties": { "hidden": { "const": true } }, "required": ["hidden"] }
          ]
        }
      },
      "then": {
        "required": ["installation"]
      }
    }
  ],
  "type": "object",
  "properties": {
    "extends": {
      "type": "string",
      "pattern": "^(local:|[^:]+).*$"
    },
    "icon": {
      "type": "string",
      "default": "icon.png"
    },
    "url": {
      "type": "string"
    },
    "documentation": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "vendor": {
      "type": "string"
    },
    "stacktype": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "supported_addons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Addon IDs this application supports. Merged with parent via extends."
    },
    "default_addons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Addon IDs preselected by default (user can deselect)."
    },
    "required_addons": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Addon IDs that are always active and cannot be deselected by the user."
    },
    "oidc_roles": {
      "type": "array",
      "description": "Zitadel role definitions for OIDC authentication. Required when 'addon-oidc' is in supported_addons.",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "description": "Role key in Zitadel (e.g. 'admin', 'user', 'readonly')"
          },
          "display_name": {
            "type": "string",
            "description": "Human-readable display name for the role"
          },
          "group": {
            "type": "string",
            "description": "Role group for organizing roles in Zitadel"
          }
        },
        "required": ["key", "display_name"],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "dependencies": {
      "type": "array",
      "description": "Applications that must be installed before this one (in the same stack)",
      "items": {
        "type": "object",
        "properties": {
          "application": {
            "type": "string",
            "description": "Application ID of the dependency"
          }
        },
        "required": ["application"],
        "additionalProperties": false
      }
    },
    "installation": {
      "$ref": "categorized-templatelist"
    },
    "upgrade": {
      "$ref": "categorized-templatelist"
    },
    "reconfigure": {
      "$ref": "categorized-templatelist"
    },
    "supports": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Feature flags this application supports (e.g. 'serial_tty', 'docker'). Merged with parent via extends. Templates with 'implements' are only included when the application has the matching value."
    },
    "check": {
      "$ref": "categorized-templatelist"
    },
    "hidden": {
      "type": "boolean",
      "default": false,
      "description": "If true, the application is not shown in the applications list but can appear in the installed list."
    },
    "verification": {
      "type": "object",
      "description": "Deprecated: Use check task instead. Post-installation verification configuration.",
      "properties": {
        "wait_seconds": {
          "type": "number"
        },
        "checks": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "boolean" },
              {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean", "default": true },
                  "fatal": { "type": "boolean", "default": true }
                },
                "additionalProperties": false
              },
              { "type": "string" },
              { "type": "number" }
            ]
          }
        }
      },
      "additionalProperties": false
    }
  },
  "unevaluatedProperties": false
}
