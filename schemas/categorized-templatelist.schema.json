{
  "$id": "categorized-templatelist",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A template list that supports both flat array format and category-based object format",
  "oneOf": [
    { "$ref": "templatelist" },
    {
      "type": "object",
      "properties": {
        "image": { "$ref": "templatelist" },
        "create_ct": { "$ref": "templatelist" },
        "pre_start": { "$ref": "templatelist" },
        "start": { "$ref": "templatelist" },
        "post_start": { "$ref": "templatelist" },
        "replace_ct": { "$ref": "templatelist" }
      }
    }
  ]
}
