{
  "$id": "addon",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "allOf": [{ "$ref": "base-deployable" }],
  "type": "object",
  "properties": {
    "required_parameters": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Parameter IDs that must exist in the application for this addon to be compatible."
    },
    "dependencies": {
      "type": "array",
      "description": "Applications that must be installed for this addon to function (in the same stack)",
      "items": {
        "type": "object",
        "properties": {
          "application": {
            "type": "string",
            "description": "Application ID of the dependency"
          }
        },
        "required": ["application"],
        "additionalProperties": false
      }
    },
    "volumes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "mount_point"],
        "properties": {
          "id": { "type": "string" },
          "mount_point": { "type": "string" },
          "default_size": { "type": "string", "default": "1G" }
        },
        "additionalProperties": false
      }
    },
    "installation": {
      "type": "object",
      "properties": {
        "pre_start": { "$ref": "templatelist" },
        "post_start": { "$ref": "templatelist" }
      },
      "additionalProperties": false
    },
    "reconfigure": {
      "type": "object",
      "properties": {
        "pre_start": { "$ref": "templatelist" },
        "post_start": { "$ref": "templatelist" }
      },
      "additionalProperties": false
    },
    "upgrade": { "$ref": "templatelist" },
    "disable": {
      "type": "object",
      "properties": {
        "pre_start": { "$ref": "templatelist" },
        "post_start": { "$ref": "templatelist" }
      },
      "additionalProperties": false
    },
    "notes_key": { "type": "string" },
    "stacktype": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "stack_usage": {
      "$ref": "stack-usage"
    }
  },
  "required": ["notes_key"],
  "unevaluatedProperties": false
}
