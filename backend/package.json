{
  "name": "oci-lxc-deployer",
  "version": "1.0.0",
  "description": "OCI LXC Deployer for Proxmox VE. Creates and manages LXC containers via Proxmox API.",
  "type": "module",
  "module": "nodenext",
  "main": "dist/index.js",
  "bin": {
    "oci-lxc-deployer": "dist/oci-lxc-deployer.mjs"
  },
  "scripts": {
    "start": "node dist/oci-lxc-deployer.mjs",
    "start:local": "node dist/oci-lxc-deployer.mjs --local ./local",
    "clinic:doctor": "clinic doctor -- node dist/oci-lxc-deployer.mjs",
    "clinic:doctor:local": "clinic doctor -- node dist/oci-lxc-deployer.mjs --local ./local",
    "clinic:flame": "clinic flame -- node dist/oci-lxc-deployer.mjs",
    "clinic:flame:local": "clinic flame -- node dist/oci-lxc-deployer.mjs --local ./local",
    "clinic:bubble": "clinic bubbleprof -- node dist/oci-lxc-deployer.mjs",
    "clinic:bubble:local": "clinic bubbleprof -- node dist/oci-lxc-deployer.mjs --local ./local",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.mts",
    "test:all": "vitest run --config vitest.config.all.mts",
    "test:templates": "vitest run --config vitest.config.template-tests.mts",
    "build": "tsc --project tsconfig.production.json && tsc-alias -p tsconfig.production.json",
    "postbuild": "chmod +x ./dist/oci-lxc-deployer.mjs && node -e \"const{execSync:e}=require('child_process');let h='unknown',d='',v='unknown';try{h=e('git rev-parse --short HEAD').toString().trim();d=e('git diff --stat HEAD').toString().trim()}catch{}try{v=require('../package.json').version}catch{try{v=require('./package.json').version}catch{}}const j={version:v,gitHash:h,buildTime:new Date().toISOString(),dirty:d.length>0};require('fs').writeFileSync('dist/build-info.json',JSON.stringify(j,null,2))\"",
    "lint:all": "eslint \"src/**/*.{ts,mts,cts}\" \"tests/**/*.{ts,mts,cts}\"",
    "lint:fix": "eslint \"src/**/*.{ts,mts,cts}\" \"tests/**/*.{ts,mts,cts}\" --fix",
    "prettier": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@angular/cli": "^20.3.10",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/fs-extra": "^11.0.4",
    "@types/json-source-map": "^0.6.0",
    "@types/jsonschema": "^0.0.5",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "clinic": "^13.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vitest": "^0.5.4",
    "fs-extra": "^11.3.2",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.12"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-errors": "^3.0.0",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "fs": "^0.0.1-security",
    "json-source-map": "^0.6.1",
    "jsonschema": "^1.5.0",
    "openid-client": "^6.8.2",
    "path": "^0.12.7",
    "socket.io": "^4.8.1",
    "winston": "^3.19.0"
  }
}
