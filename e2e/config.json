{
  "default": "local-test",
  "instances": {
    "dev": {
      "description": "Local development (deployer runs on localhost)",
      "pveHost": "${PVE_HOST:-ubuntupve}",
      "vmId": 9000,
      "vmName": "pve-e2e-dev",
      "portOffset": 0,
      "subnet": "10.99.1",
      "bridge": "vmbr1",
      "filesystem": "zfs",
      "deployerHost": "localhost",
      "deployerPort": "${DEPLOYER_PORT}"
    },
    "local-test": {
      "description": "Local development testing",
      "pveHost": "${PVE_HOST:-ubuntupve}",
      "vmId": 9000,
      "vmName": "pve-e2e-local",
      "portOffset": 0,
      "subnet": "10.99.1",
      "bridge": "vmbr1",
      "localPath": "./examples",
      "filesystem": "zfs",
      "veHost": "pve-e2e-nested.local",
      "veSshPort": 22
    },
    "github-action": {
      "description": "GitHub Actions CI testing",
      "pveHost": "${PVE_HOST:-ubuntupve}",
      "vmId": 9001,
      "vmName": "pve-e2e-ci",
      "portOffset": 1000,
      "subnet": "10.99.2",
      "bridge": "vmbr2",
      "filesystem": "ext4",
      "wol": {
        "macAddress": "XX:XX:XX:XX:XX:XX"
      }
    }
  },
  "defaults": {
    "vmMemory": 4096,
    "vmCores": 2,
    "vmDiskSize": 100,
    "vmStorage": "local-zfs",
    "filesystem": "zfs",
    "swapSize": 4,
    "nestedPassword": "e2e-test-2024",
    "owner": "modbus2mqtt",
    "ociOwner": "modbus2mqtt",
    "deployerVmid": 300,
    "deployerBridge": "vmbr1",
    "deployerStaticIp": "10.0.0.100/24",
    "deployerGateway": "10.0.0.1"
  },
  "ports": {
    "pveWeb": 1008,
    "pveSsh": 1022,
    "deployer": 1080,
    "deployerHttps": 1443,
    "testWorkerSsh": 2222
  }
}
